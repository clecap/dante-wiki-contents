('en','messages:apiwarn-moduleswithoutvars','s:165:\"Property <kbd>modules</kbd> was set but not <kbd>jsconfigvars</kbd> or <kbd>encodedjsconfigvars</kbd>. Configuration variables are necessary for proper module usage.\";'),
