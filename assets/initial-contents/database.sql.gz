('en','messages:confirmemail_oncreate','s:174:\"A confirmation code was sent to your email address.\nThis code is not required to log in, but you will need to provide it before enabling any email-based features in the wiki.\";'),
('en','messages:confirmemail_pending','s:179:\"A confirmation code has already been emailed to you;\nif you recently created your account, you may wish to wait a few minutes for it to arrive before trying to request a new code.\";'),
('en','messages:confirmemail_send','s:24:\"Mail a confirmation code\";'),
