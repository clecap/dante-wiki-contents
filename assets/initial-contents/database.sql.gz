('en','messages:apihelp-query+filerepoinfo-paramvalue-prop-articlepath','s:106:\"Repository wiki\'s <var>[[mw:Special:MyLanguage/Manual:$wgArticlePath|$wgArticlePath]]</var> or equivalent.\";'),
