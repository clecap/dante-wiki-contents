(20,'== Test for Parsifal Page Width ==\nPre\n<amsmath>\nEi nz el test aq qwehj hjk hjk 789\n \nRule of 14cm\n\\hrule height 1px depth 1px width 14cm \\relax\n\nRule of 15cm\n\\hrule height 1px depth 1px width 15cm \\relax\n\nRule of 16cm\n\\hrule height 1px depth 1px width 16cm \\relax\n</amsmath>\n\n== Setting Page Width ==\n<amsmath slim b>\nThis is a slim page \n</amsmath>\n\n<amsmath width=\"25cm\">\nWidth 25cm \n</amsmath>\n\n<amsmath width=\"5cm\">\nWidth 5cm \n</amsmath>\n\n<amsmath width=\"15cm\">\nWidth 15cm \n</amsmath>\n\n<amsmath width=\"14cm\">\nWidth 14cm \n</amsmath>\n\n<amsmath width=\"13cm\">\nWidth 13cm \n</amsmath>\n\n\n\n<amsmath width=\"50cm\">\nWidth 50cm  \n</amsmath>\n\n== Wide Page ==\n<amsmath wide>\nThis is a wide page which is able to contain quite\na lot of text provided we enter enough text to fill the\nthe page which has a lot of space.  \n\n{\\color{red}asd asd asd asd asd asd asd asd}\n\n\\begin{enumerate}\n\\item a\n\\item b\n\\end{enumerate}\naSome more\n\n</amsmath>\n\n<amsmath wide>\nThis is a wide pagej\n</amsmath>\n\n<amsmath>\nThis is a normal page.\n</amsmath>\n\n== Setting Size ==\n<amsmath width=\"1cm\" scale=\"3\" b>\nOne centimetersss s\n\n</amsmath>\n\n== PDF Scale Adjustment ==\n<amsmath pdfscale=\"7\">\n7\n</amsmath>\n\n<amsmath pdfscale=\"8\">\n8\n</amsmath>\n\n<amsmath pdfscale=\"9\">\n9\n</amsmath>\n\n<amsmath pdfscale=\"20\">\n20\n</amsmath>\n\n<amsmath pdfscale=\"1\">\n1 20\n</amsmath>\n\n\n== Margin adjustment ==\n<amsmath>\nNo margin adjustments\n</amsmath>\n\n<amsmath margin=\"0.07cm\">\nNow margin=0.07cm\n</amsmath>\n\n<amsmath margin=\"0.5cm\">\nNow margin=0.5cm\n</amsmath>\n\n<amsmath margin=\"{0.0cm 0.0cm 0.0cm 3cm}\">\nNow margin=0.0cm 0.0cm 0.0cm 3cm  as in left bottom right top\n</amsmath>\n[[Category:DanteInitialContents]]','utf-8'),
