('en','messages:apiwarn-parse-revidwithouttext','s:155:\"<var>revid</var> used without <var>text</var>, and parsed page properties were requested. Did you mean to use <var>oldid</var> instead of <var>revid</var>?\";'),
('en','messages:apiwarn-parse-titlewithouttext','s:154:\"<var>title</var> used without <var>text</var>, and parsed page properties were requested. Did you mean to use <var>page</var> instead of <var>title</var>?\";'),
