('en','messages:passwordpolicies-policy-display','s:65:\"<span class=\"passwordpolicies-policy\">$1 <code>($2)</code></span>\";'),
('en','messages:passwordpolicies-policy-displaywithflags','s:121:\"<span class=\"passwordpolicies-policy\">$1 <code>($2)</code></span> <span class=\"passwordpolicies-policy-flags\">($3)</span>\";'),
('en','messages:passwordpolicies-policy-maximalpasswordlength','s:69:\"Password must be less than $1 {{PLURAL:$1|character|characters}} long\";'),
